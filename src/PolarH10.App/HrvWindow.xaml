<Window x:Class="PolarH10.App.HrvWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Polar H10 // HRV"
        Width="1180"
        Height="920"
        MinWidth="1040"
        MinHeight="760"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="PanelFrameStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource AppPaperBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelEdgeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="DarkPanelFrameStyle" TargetType="Border" BasedOn="{StaticResource PanelFrameStyle}">
            <Setter Property="Background" Value="{StaticResource SurfaceTintBrush}" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource CarbonBrush}" />
        </Style>

        <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource GraphiteBrush}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="ReadinessProgressStyle" TargetType="ProgressBar">
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="1" />
            <Setter Property="Height" Value="10" />
            <Setter Property="Background" Value="{StaticResource SurfaceTintBrush}" />
            <Setter Property="Foreground" Value="{StaticResource FocusBlueBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelEdgeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ProgressBar}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                SnapsToDevicePixels="True">
                            <Grid x:Name="PART_Track"
                                  ClipToBounds="True"
                                  Background="Transparent">
                                <Border x:Name="PART_Indicator"
                                        HorizontalAlignment="Left"
                                        Background="{TemplateBinding Foreground}"
                                        CornerRadius="4" />
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ConsoleListStyle" TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource AppPaperBrush}" />
            <Setter Property="Foreground" Value="{StaticResource CarbonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelEdgeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="ConsoleListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource CarbonBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SurfaceLightBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SurfaceTintBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20,18,20,12">
            <Border Style="{StaticResource DarkPanelFrameStyle}">
                <StackPanel>
                    <TextBlock x:Name="SelectedHrvDeviceText"
                               Text="No device selected"
                               FontSize="30"
                               FontWeight="Bold"
                               Margin="0,0,0,4" />
                    <TextBlock x:Name="HrvWindowSummaryText"
                               Text="RMSSD is the headline short-term HRV value; supporting telemetry includes SDNN, pNN50, SD1, mean NN, and mean HR from the accepted RR window."
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource GraphiteBrush}" />
                </StackPanel>
            </Border>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource DarkPanelFrameStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="RMSSD" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock x:Name="HrvValueText"
                                   Text="--"
                                   FontSize="54"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource FocusBlueBrush}" />
                        <TextBlock x:Name="HrvStateValueText"
                                   Text="Unavailable"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,4,0,0" />
                        <TextBlock x:Name="HrvTrackingValueText"
                                   Text="Waiting for RR input"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource GraphiteBrush}"
                                   Margin="0,8,0,0" />
                        <TextBlock x:Name="HrvSupportValueText"
                                   Text="SDNN -- | pNN50 --"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource GraphiteBrush}"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource PanelFrameStyle}">
                    <StackPanel>
                        <TextBlock Text="Control" Style="{StaticResource MetricLabelStyle}" />
                        <WrapPanel>
                            <Button Content="Reset tracker"
                                    Width="112"
                                    Margin="0,0,8,8"
                                    Click="OnResetTrackerClick" />
                            <Button Content="Apply tuning"
                                    Width="108"
                                    Margin="0,0,8,8"
                                    Click="OnApplyTuningClick" />
                            <Button Content="Restore defaults"
                                    Width="128"
                                    Margin="0,0,0,8"
                                    Background="{StaticResource AppPaperBrush}"
                                    Foreground="{StaticResource CarbonBrush}"
                                    BorderBrush="{StaticResource PanelEdgeBrush}"
                                    Click="OnRestoreDefaultsClick" />
                        </WrapPanel>
                        <TextBlock x:Name="HrvStatusText"
                                   Text="No device selected"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource GraphiteBrush}"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock Text="Readiness"
                       Style="{StaticResource SectionTitleStyle}"
                       Margin="0,0,0,8" />
            <Border Style="{StaticResource PanelFrameStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.15*" />
                        <ColumnDefinition Width="0.85*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,18,0">
                        <TextBlock x:Name="HrvRequirementText"
                                   Text="The first short-term HRV solve waits for RR accumulation and nearly a full buffered RR window."
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="HrvWarmupHintText"
                                   Text="Connect a device and stream RR intervals to begin filling the short-term window."
                                   FontSize="13"
                                   Foreground="{StaticResource GraphiteBrush}"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Accepted RR samples"
                                       Style="{StaticResource MetricLabelStyle}"
                                       Margin="0,0,0,0" />
                            <TextBlock x:Name="HrvReadinessSamplesText"
                                       Grid.Column="1"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Right" />
                        </Grid>

                        <ProgressBar x:Name="HrvReadinessSamplesBar"
                                     Grid.Row="1"
                                     Style="{StaticResource ReadinessProgressStyle}"
                                     Margin="0,4,0,0" />

                        <Grid Grid.Row="2"
                              Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Buffered RR window"
                                       Style="{StaticResource MetricLabelStyle}"
                                       Margin="0,0,0,0" />
                            <TextBlock x:Name="HrvReadinessCoverageText"
                                       Grid.Column="1"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Right" />
                        </Grid>

                        <ProgressBar x:Name="HrvReadinessCoverageBar"
                                     Grid.Row="3"
                                     Style="{StaticResource ReadinessProgressStyle}"
                                     Margin="0,4,0,0" />

                        <TextBlock x:Name="HrvReadinessRemainingText"
                                   Grid.Row="4"
                                   Margin="0,12,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource GraphiteBrush}"
                                   TextWrapping="Wrap" />
                    </Grid>
                </Grid>
            </Border>

            <TextBlock Text="HRV telemetry"
                       Style="{StaticResource SectionTitleStyle}"
                       Margin="0,0,0,8" />
            <Border x:Name="HrvChartHost"
                    Style="{StaticResource PanelFrameStyle}"
                    Height="214"
                    Padding="0"
                    Margin="0,0,0,10" />

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PanelFrameStyle}" Margin="0,0,10,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="State" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock x:Name="HrvTelemetryTrackingText" Grid.Column="1" FontSize="14" FontWeight="SemiBold" />

                        <TextBlock Grid.Row="1" Text="Last RR" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock x:Name="HrvTelemetryLastRrText" Grid.Row="1" Grid.Column="1" FontSize="14" FontWeight="SemiBold" />

                        <TextBlock Grid.Row="2" Text="Heartbeat" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock x:Name="HrvTelemetryHeartbeatText" Grid.Row="2" Grid.Column="1" FontSize="14" FontWeight="SemiBold" />

                        <TextBlock Grid.Row="3" Text="RR seen" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock x:Name="HrvTelemetrySampleCountText" Grid.Row="3" Grid.Column="1" FontSize="14" FontWeight="SemiBold" />

                        <TextBlock Grid.Row="4" Text="RR in window" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock x:Name="HrvTelemetryWindowCountText" Grid.Row="4" Grid.Column="1" FontSize="14" FontWeight="SemiBold" />

                        <TextBlock Grid.Row="5" Text="Window fill" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock x:Name="HrvTelemetryCoverageText" Grid.Row="5" Grid.Column="1" FontSize="14" FontWeight="SemiBold" />
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource PanelFrameStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Last update" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock x:Name="HrvTelemetryLastUpdateText" Grid.Column="1" FontSize="14" FontWeight="SemiBold" />

                        <TextBlock Grid.Row="1" Text="Mean NN" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock x:Name="HrvTelemetryMeanNnText" Grid.Row="1" Grid.Column="1" FontSize="14" FontWeight="SemiBold" />

                        <TextBlock Grid.Row="2" Text="Mean HR" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock x:Name="HrvTelemetryMeanHrText" Grid.Row="2" Grid.Column="1" FontSize="14" FontWeight="SemiBold" />

                        <TextBlock Grid.Row="3" Text="SDNN" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock x:Name="HrvTelemetrySdnnText" Grid.Row="3" Grid.Column="1" FontSize="14" FontWeight="SemiBold" />

                        <TextBlock Grid.Row="4" Text="pNN50" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock x:Name="HrvTelemetryPnn50Text" Grid.Row="4" Grid.Column="1" FontSize="14" FontWeight="SemiBold" />

                        <TextBlock Grid.Row="5" Text="SD1" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock x:Name="HrvTelemetrySd1Text" Grid.Row="5" Grid.Column="1" FontSize="14" FontWeight="SemiBold" />

                        <TextBlock Grid.Row="6" Text="lnRMSSD" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock x:Name="HrvTelemetryLnRmssdText" Grid.Row="6" Grid.Column="1" FontSize="14" FontWeight="SemiBold" />
                    </Grid>
                </Border>
            </Grid>

            <TextBlock Text="Tuning"
                       Style="{StaticResource SectionTitleStyle}"
                       Margin="0,0,0,8" />
            <Border Style="{StaticResource PanelFrameStyle}">
                <StackPanel>
                    <TextBlock Margin="0,0,0,12"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource GraphiteBrush}"
                               TextWrapping="Wrap">
                        Shaffer and Ginsberg (2017) treat five minutes as the conventional short-term HRV recording standard. Shorter windows here are for operator preview only, not a substitute for 24 h norms or full artifact-corrected analysis.
                    </TextBlock>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="118" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="118" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Min RR samples" Style="{StaticResource MetricLabelStyle}" />
                        <TextBox x:Name="HrvMinimumRrSamplesBox"
                                 Grid.Column="1"
                                 Margin="0,0,0,8"
                                 ToolTip="Accepted RR intervals required before the tracker publishes the first HRV solve." />
                        <TextBlock Grid.Column="3" Text="Window (s)" Style="{StaticResource MetricLabelStyle}" />
                        <TextBox x:Name="HrvWindowSecondsBox"
                                 Grid.Column="4"
                                 Margin="0,0,0,8"
                                 ToolTip="Rolling RR history used for the short-term HRV solve. Five minutes is the reference default." />

                        <TextBlock Grid.Row="1" Text="Stale timeout (s)" Style="{StaticResource MetricLabelStyle}" />
                        <TextBox x:Name="HrvStaleTimeoutBox"
                                 Grid.Row="1"
                                 Grid.Column="1"
                                 ToolTip="How long the latest HRV solve remains live before it is marked stale." />
                        <TextBlock Grid.Row="1" Grid.Column="3" Text="Fixed metrics" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock Grid.Row="1"
                                   Grid.Column="4"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource GraphiteBrush}"
                                   TextWrapping="Wrap"
                                   Text="RMSSD, SDNN, pNN50, SD1, mean NN, mean HR" />
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock Text="HRV log"
                       Style="{StaticResource SectionTitleStyle}"
                       Margin="0,4,0,8" />
            <ListBox x:Name="HrvLogList"
                     Height="140"
                     Style="{StaticResource ConsoleListStyle}"
                     ItemContainerStyle="{StaticResource ConsoleListItemStyle}" />
        </StackPanel>
    </ScrollViewer>
</Window>
