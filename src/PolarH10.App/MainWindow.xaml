<Window x:Class="PolarH10.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="Polar H10 // Telemetry Unit"
        Width="1360"
        Height="940"
        MinWidth="1160"
        MinHeight="820"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="PanelFrameStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource AppPaperBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelEdgeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="DarkPanelFrameStyle" TargetType="Border" BasedOn="{StaticResource PanelFrameStyle}">
            <Setter Property="Background" Value="{StaticResource SurfaceTintBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelEdgeBrush}" />
        </Style>

        <Style x:Key="SectionCodeStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource GraphiteBrush}" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource CarbonBrush}" />
        </Style>

        <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource GraphiteBrush}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="ConsoleListStyle" TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource AppPaperBrush}" />
            <Setter Property="Foreground" Value="{StaticResource CarbonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelEdgeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="ConsoleListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource CarbonBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SurfaceLightBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SurfaceTintBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DeviceRailListStyle" TargetType="ListBox" BasedOn="{StaticResource ConsoleListStyle}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource CarbonBrush}" />
            <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="DeviceRailListItemStyle" TargetType="ListBoxItem" BasedOn="{StaticResource ConsoleListItemStyle}">
            <Setter Property="Foreground" Value="{StaticResource CarbonBrush}" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="Chrome"
                                Background="{StaticResource AppPaperBrush}"
                                BorderBrush="{StaticResource PanelEdgeBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource AppPaperBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource FocusBlueBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource CarbonBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource FocusBlueBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="10" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Rectangle Grid.Column="0" Fill="{StaticResource FocusBlueBrush}" />
            <Rectangle Grid.Column="1" Fill="{StaticResource TelemetryGreenBrush}" />
            <Rectangle Grid.Column="2" Fill="{StaticResource HazardYellowBrush}" />
            <Rectangle Grid.Column="3" Fill="{StaticResource SafetyOrangeBrush}" />
            <Rectangle Grid.Column="4" Fill="{StaticResource SignalRedBrush}" />
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="312" MinWidth="240" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource SurfaceTintBrush}"
                    BorderBrush="{StaticResource PanelEdgeBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel Margin="18" LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                        <TextBlock Text="Devices"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource CarbonBrush}"
                                   Margin="0,0,0,12" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="ScanButton"
                                    Content="Scan"
                                    Width="88"
                                    Click="OnScanClick" />
                            <TextBlock x:Name="ScanStatusText"
                                       Grid.Column="1"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"
                                       Foreground="{StaticResource GraphiteBrush}"
                                       FontSize="12"
                                       Text="" />
                        </Grid>
                    </StackPanel>

                    <ListBox x:Name="DeviceListBox"
                             SelectionChanged="OnDeviceSelectionChanged"
                             Style="{StaticResource DeviceRailListStyle}"
                             ItemContainerStyle="{StaticResource DeviceRailListItemStyle}" />
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch" />

            <Grid Grid.Column="2" Background="{StaticResource AppPaperBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource SurfaceTintBrush}"
                        BorderBrush="{StaticResource PanelEdgeBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="20,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4">
                            <TextBlock x:Name="SelectedDeviceLabel"
                                       Text="No device selected"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Margin="0,0,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                    Grid.Column="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,14,0,0">
                            <TextBlock Text="Alias" Style="{StaticResource MetricLabelStyle}" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBox x:Name="AliasBox" Width="180" Margin="0,0,8,0" />
                            <Button x:Name="SetAliasButton"
                                    Content="Save"
                                    Width="68"
                                    Background="{StaticResource AppPaperBrush}"
                                    Foreground="{StaticResource CarbonBrush}"
                                    BorderBrush="{StaticResource PanelEdgeBrush}"
                                    Click="OnSetAliasClick" />
                        </StackPanel>

                        <Button x:Name="ConnectButton"
                                Grid.Row="1"
                                Grid.Column="1"
                                Content="Connect"
                                Width="96"
                                Margin="12,14,6,0"
                                Click="OnConnectClick" />
                        <Button x:Name="DisconnectButton"
                                Grid.Row="1"
                                Grid.Column="2"
                                Content="Disconnect"
                                Width="104"
                                Margin="0,14,8,0"
                                Background="{StaticResource AppPaperBrush}"
                                Foreground="{StaticResource CarbonBrush}"
                                BorderBrush="{StaticResource PanelEdgeBrush}"
                                Click="OnDisconnectClick"
                                IsEnabled="False" />
                        <TextBlock x:Name="StatusText"
                                   Grid.Row="1"
                                   Grid.Column="3"
                                   VerticalAlignment="Center"
                                   Margin="10,14,0,0"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource GraphiteBrush}"
                                   Text="" />
                    </Grid>
                </Border>

                <TabControl x:Name="DeviceTabControl" Grid.Row="1" Margin="20,18,20,12">
                    <TabItem Header="Live">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.15*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Style="{StaticResource DarkPanelFrameStyle}" Margin="0,0,10,0">
                                        <StackPanel>
                                            <TextBlock Text="Heart rate" Style="{StaticResource MetricLabelStyle}" />
                                            <TextBlock x:Name="HrValueText"
                                                       Text="-- BPM"
                                                       FontSize="54"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource SignalRedBrush}" />
                                            <TextBlock x:Name="RrValueText"
                                                       Text="RR intervals --"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource GraphiteBrush}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" Style="{StaticResource PanelFrameStyle}" Margin="0">
                                        <StackPanel>
                                            <TextBlock Text="Session counters" Style="{StaticResource MetricLabelStyle}" />
                                            <TextBlock x:Name="HrCountText" Text="HR samples 0" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4" />
                                            <TextBlock x:Name="EcgCountText" Text="ECG frames 0" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4" />
                                            <TextBlock x:Name="AccCountText" Text="ACC frames 0" FontSize="16" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <TextBlock Text="Live telemetry"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Margin="0,0,0,8" />

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Button x:Name="TrackedDevicesButton"
                                            Content="Tracked devices"
                                            Width="120"
                                            Click="OnTrackedDevicesButtonClick" />

                                    <TextBlock x:Name="TrackedDevicesSummaryText"
                                               Grid.Column="1"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource GraphiteBrush}"
                                               Text="Following selected device" />

                                    <primitives:Popup x:Name="TrackedDevicesPopup"
                                                      PlacementTarget="{Binding ElementName=TrackedDevicesButton}"
                                                      Placement="Bottom"
                                                      StaysOpen="False"
                                                      AllowsTransparency="True"
                                                      PopupAnimation="Fade">
                                        <Border Background="{StaticResource AppPaperBrush}"
                                                BorderBrush="{StaticResource PanelEdgeBrush}"
                                                BorderThickness="1"
                                                Padding="12"
                                                Width="280">
                                            <StackPanel>
                                                <CheckBox x:Name="FollowSelectedTrackingCheckBox"
                                                          Content="Follow selected device"
                                                          IsChecked="True"
                                                          Margin="0,0,0,10"
                                                          Checked="OnFollowSelectedTrackingChanged"
                                                          Unchecked="OnFollowSelectedTrackingChanged" />
                                                <TextBlock Text="Tracked on charts"
                                                           Style="{StaticResource MetricLabelStyle}"
                                                           Margin="0,0,0,8" />
                                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                              MaxHeight="220">
                                                    <StackPanel x:Name="TrackedDevicesPanel" />
                                                </ScrollViewer>
                                            </StackPanel>
                                        </Border>
                                    </primitives:Popup>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border x:Name="HrChartHost"
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            Style="{StaticResource PanelFrameStyle}"
                                            Height="120"
                                            Padding="0"
                                            Margin="0,0,10,10" />
                                    <Border x:Name="RrChartHost"
                                            Grid.Row="0"
                                            Grid.Column="1"
                                            Style="{StaticResource PanelFrameStyle}"
                                            Height="120"
                                            Padding="0"
                                            Margin="0,0,0,10" />
                                    <Border x:Name="EcgChartHost"
                                            Grid.Row="1"
                                            Grid.ColumnSpan="2"
                                            Style="{StaticResource PanelFrameStyle}"
                                            Height="188"
                                            Padding="0"
                                            Margin="0,0,0,10" />

                                    <TextBlock Grid.Row="2"
                                               Grid.ColumnSpan="2"
                                               Text="Acceleration"
                                               Style="{StaticResource SectionTitleStyle}"
                                               Margin="0,0,0,8" />
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border x:Name="AccXChartHost"
                                            Grid.Column="0"
                                            Style="{StaticResource PanelFrameStyle}"
                                            Height="118"
                                            Padding="0"
                                            Margin="0,0,10,0" />
                                    <Border x:Name="AccYChartHost"
                                            Grid.Column="1"
                                            Style="{StaticResource PanelFrameStyle}"
                                            Height="118"
                                            Padding="0"
                                            Margin="0,0,10,0" />
                                    <Border x:Name="AccZChartHost"
                                            Grid.Column="2"
                                            Style="{StaticResource PanelFrameStyle}"
                                            Height="118"
                                            Padding="0" />
                                </Grid>

                                <TextBlock Text="Live log"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Margin="0,4,0,8" />
                                <ListBox x:Name="LiveLogList"
                                         Height="122"
                                         Style="{StaticResource ConsoleListStyle}"
                                         ItemContainerStyle="{StaticResource ConsoleListItemStyle}" />
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Overlay">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Style="{StaticResource PanelFrameStyle}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock x:Name="OverlayTrackingSummaryText"
                                               Text="Overlay follows the selected device"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource GraphiteBrush}"
                                               Margin="0,0,0,10" />
                                    <WrapPanel>
                                    <CheckBox x:Name="OvHrToggle" Content="HR" IsChecked="True" Margin="0,0,18,0"
                                              Foreground="{StaticResource SignalRedBrush}"
                                              Checked="OnOverlayToggle" Unchecked="OnOverlayToggle" />
                                    <CheckBox x:Name="OvRrToggle" Content="RR" IsChecked="True" Margin="0,0,18,0"
                                              Foreground="{StaticResource HazardYellowBrush}"
                                              Checked="OnOverlayToggle" Unchecked="OnOverlayToggle" />
                                    <CheckBox x:Name="OvEcgToggle" Content="ECG" IsChecked="True" Margin="0,0,18,0"
                                              Foreground="{StaticResource TelemetryCyanBrush}"
                                              Checked="OnOverlayToggle" Unchecked="OnOverlayToggle" />
                                    <CheckBox x:Name="OvAccXToggle" Content="ACC X" IsChecked="True" Margin="0,0,18,0"
                                              Foreground="{StaticResource SafetyOrangeBrush}"
                                              Checked="OnOverlayToggle" Unchecked="OnOverlayToggle" />
                                    <CheckBox x:Name="OvAccYToggle" Content="ACC Y" IsChecked="True" Margin="0,0,18,0"
                                              Foreground="{StaticResource TelemetryGreenBrush}"
                                              Checked="OnOverlayToggle" Unchecked="OnOverlayToggle" />
                                    <CheckBox x:Name="OvAccZToggle" Content="ACC Z" IsChecked="True"
                                              Foreground="{StaticResource GraphiteBrush}"
                                              Checked="OnOverlayToggle" Unchecked="OnOverlayToggle" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <Border x:Name="OverlayChartHost" Grid.Row="1" Style="{StaticResource PanelFrameStyle}" Padding="0" Margin="0" />
                        </Grid>
                    </TabItem>

                    <TabItem Header="Record">
                        <StackPanel>
                            <Border Style="{StaticResource PanelFrameStyle}">
                                <StackPanel>
                                    <TextBlock Text="Output folder" Style="{StaticResource MetricLabelStyle}" />
                                    <TextBox x:Name="OutputFolderBox" Width="360" Text="./session" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource PanelFrameStyle}">
                                <StackPanel>
                                    <TextBlock Text="Capture control" Style="{StaticResource MetricLabelStyle}" />
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="StartRecordButton"
                                                Content="Start recording"
                                                Width="132"
                                                Click="OnStartRecordClick" />
                                        <Button x:Name="StopRecordButton"
                                                Content="Stop and save"
                                                Width="132"
                                                Margin="8,0,0,0"
                                                Background="{StaticResource AppPaperBrush}"
                                                Foreground="{StaticResource CarbonBrush}"
                                                BorderBrush="{StaticResource PanelEdgeBrush}"
                                                Click="OnStopRecordClick"
                                                IsEnabled="False" />
                                    </StackPanel>
                                    <TextBlock x:Name="RecordStatusText"
                                               Text="Not recording"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource GraphiteBrush}"
                                               Margin="0,12,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="Diagnostics">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Control log"
                                       Style="{StaticResource SectionTitleStyle}"
                                       Margin="0,0,0,10" />
                            <ListBox x:Name="DiagLogList"
                                     Grid.Row="1"
                                     Style="{StaticResource ConsoleListStyle}"
                                     ItemContainerStyle="{StaticResource ConsoleListItemStyle}" />
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource SurfaceTintBrush}"
                BorderBrush="{StaticResource PanelEdgeBrush}"
                BorderThickness="0,1,0,0"
                Padding="14,8">
            <TextBlock Text="Unofficial Polar H10 reference monitor. Not affiliated with or endorsed by Polar."
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource GraphiteBrush}" />
        </Border>
    </Grid>
</Window>
