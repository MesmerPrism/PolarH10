<Window x:Class="PolarH10.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Polar H10 Monitor — Multi-Device" Height="900" Width="1200"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" MinWidth="200" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ===== LEFT: Device List Panel ===== -->
        <DockPanel Grid.Column="0">
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                <TextBlock Text="Devices" FontSize="16" FontWeight="Bold" Margin="0,0,0,4" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <Button x:Name="ScanButton" Content="Scan" Width="60" Margin="0,0,4,0" Click="OnScanClick" />
                    <TextBlock x:Name="ScanStatusText" Text="" VerticalAlignment="Center" Foreground="Gray" FontSize="11" />
                </StackPanel>
            </StackPanel>

            <!-- Scanned / connected device list -->
            <ListBox x:Name="DeviceListBox" DockPanel.Dock="Top"
                     SelectionChanged="OnDeviceSelectionChanged"
                     FontFamily="Consolas" FontSize="11" />
        </DockPanel>

        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      Background="LightGray" />

        <!-- ===== RIGHT: Selected Device Detail ===== -->
        <DockPanel Grid.Column="2">

            <!-- Device header bar -->
            <Grid DockPanel.Dock="Top" Margin="4,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="SelectedDeviceLabel" Grid.Column="0" Text="No device selected"
                           FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Alias:" VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBox x:Name="AliasBox" Width="120" Margin="0,0,4,0" />
                    <Button x:Name="SetAliasButton" Content="Set" Width="40" Click="OnSetAliasClick" />
                </StackPanel>
                <Button x:Name="ConnectButton" Grid.Column="2" Content="Connect" Width="75" Margin="8,0,4,0" Click="OnConnectClick" />
                <Button x:Name="DisconnectButton" Grid.Column="3" Content="Disconnect" Width="85" Margin="0,0,4,0" Click="OnDisconnectClick" IsEnabled="False" />
                <TextBlock x:Name="StatusText" Grid.Column="4" Text="" VerticalAlignment="Center" Foreground="Gray" Margin="8,0,0,0" />
            </Grid>

            <!-- Tabs for the selected device -->
            <TabControl x:Name="DeviceTabControl" Margin="4,0,0,0">

                <!-- ===== LIVE TAB ===== -->
                <TabItem Header="Live">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- HR + Counters cards -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" BorderBrush="LightGray" BorderThickness="1" Margin="4" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="Heart Rate" FontSize="14" FontWeight="SemiBold" />
                                        <TextBlock x:Name="HrValueText" Text="-- bpm" FontSize="36" FontWeight="Bold" Foreground="Red" />
                                        <TextBlock x:Name="RrValueText" Text="RR: --" FontSize="12" Foreground="Gray" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" BorderBrush="LightGray" BorderThickness="1" Margin="4" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="Packet Counters" FontSize="14" FontWeight="SemiBold" />
                                        <TextBlock x:Name="HrCountText" Text="HR: 0" />
                                        <TextBlock x:Name="EcgCountText" Text="ECG frames: 0" />
                                        <TextBlock x:Name="AccCountText" Text="ACC frames: 0" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Waveform charts -->
                            <Border x:Name="HrChartHost" Height="120" Margin="4,8,4,2" />
                            <Border x:Name="RrChartHost" Height="120" Margin="4,2,4,2" />
                            <Border x:Name="EcgChartHost" Height="160" Margin="4,2,4,2" />
                            <Border x:Name="AccXChartHost" Height="120" Margin="4,2,4,2" />
                            <Border x:Name="AccYChartHost" Height="120" Margin="4,2,4,2" />
                            <Border x:Name="AccZChartHost" Height="120" Margin="4,2,4,2" />

                            <!-- Log -->
                            <ListBox x:Name="LiveLogList" Height="120" Margin="4,8,4,4"
                                     FontFamily="Consolas" FontSize="11" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ===== OVERLAY TAB ===== -->
                <TabItem Header="Overlay">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <WrapPanel Grid.Row="0" Margin="4,4,4,0">
                            <CheckBox x:Name="OvHrToggle"   Content=" HR"    IsChecked="True" Margin="0,0,16,0" Foreground="Red"        FontWeight="SemiBold" Checked="OnOverlayToggle" Unchecked="OnOverlayToggle" />
                            <CheckBox x:Name="OvRrToggle"   Content=" RR"    IsChecked="True" Margin="0,0,16,0" Foreground="RoyalBlue"  FontWeight="SemiBold" Checked="OnOverlayToggle" Unchecked="OnOverlayToggle" />
                            <CheckBox x:Name="OvEcgToggle"  Content=" ECG"   IsChecked="True" Margin="0,0,16,0" Foreground="Green"      FontWeight="SemiBold" Checked="OnOverlayToggle" Unchecked="OnOverlayToggle" />
                            <CheckBox x:Name="OvAccXToggle"  Content=" ACC X" IsChecked="True" Margin="0,0,16,0" Foreground="DarkOrange" FontWeight="SemiBold" Checked="OnOverlayToggle" Unchecked="OnOverlayToggle" />
                            <CheckBox x:Name="OvAccYToggle"  Content=" ACC Y" IsChecked="True" Margin="0,0,16,0" Foreground="Purple"     FontWeight="SemiBold" Checked="OnOverlayToggle" Unchecked="OnOverlayToggle" />
                            <CheckBox x:Name="OvAccZToggle"  Content=" ACC Z" IsChecked="True" Margin="0,0,16,0" Foreground="SaddleBrown" FontWeight="SemiBold" Checked="OnOverlayToggle" Unchecked="OnOverlayToggle" />
                        </WrapPanel>

                        <Border x:Name="OverlayChartHost" Grid.Row="1" Margin="4" />
                    </Grid>
                </TabItem>

                <!-- ===== RECORD TAB ===== -->
                <TabItem Header="Record">
                    <StackPanel Margin="12">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Output folder:" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBox x:Name="OutputFolderBox" Width="300" Text="./session" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button x:Name="StartRecordButton" Content="Start Recording" Width="120" Click="OnStartRecordClick" />
                            <Button x:Name="StopRecordButton" Content="Stop &amp; Save" Width="100" Margin="8,0,0,0" Click="OnStopRecordClick" IsEnabled="False" />
                        </StackPanel>
                        <TextBlock x:Name="RecordStatusText" Text="Not recording" Foreground="Gray" />
                    </StackPanel>
                </TabItem>

                <!-- ===== DIAGNOSTICS TAB ===== -->
                <TabItem Header="Diagnostics">
                    <ListBox x:Name="DiagLogList" Margin="4" FontFamily="Consolas" FontSize="11" />
                </TabItem>

            </TabControl>
        </DockPanel>

        <TextBlock Grid.Column="0" Grid.ColumnSpan="3" VerticalAlignment="Bottom"
                   Text="Unofficial Polar H10 reference monitor. Not affiliated with or endorsed by Polar."
                   FontSize="10" Foreground="Gray" Margin="0,8,0,0" />
    </Grid>
</Window>
