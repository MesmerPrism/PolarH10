<Window x:Class="PolarH10.App.CoherenceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Polar H10 // Coherence"
        Width="1180"
        Height="920"
        MinWidth="1040"
        MinHeight="760"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="PanelFrameStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource AppPaperBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelEdgeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="DarkPanelFrameStyle" TargetType="Border" BasedOn="{StaticResource PanelFrameStyle}">
            <Setter Property="Background" Value="{StaticResource SurfaceTintBrush}" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource CarbonBrush}" />
        </Style>

        <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource GraphiteBrush}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="ReadinessProgressStyle" TargetType="ProgressBar">
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="1" />
            <Setter Property="Height" Value="10" />
            <Setter Property="Background" Value="{StaticResource SurfaceTintBrush}" />
            <Setter Property="Foreground" Value="{StaticResource FocusBlueBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelEdgeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ProgressBar}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                SnapsToDevicePixels="True">
                            <Grid x:Name="PART_Track"
                                  ClipToBounds="True"
                                  Background="Transparent">
                                <Border x:Name="PART_Indicator"
                                        HorizontalAlignment="Left"
                                        Background="{TemplateBinding Foreground}"
                                        CornerRadius="4" />
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ConsoleListStyle" TargetType="ListBox">
            <Setter Property="Background" Value="{StaticResource AppPaperBrush}" />
            <Setter Property="Foreground" Value="{StaticResource CarbonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelEdgeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="ConsoleListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource CarbonBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SurfaceLightBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SurfaceTintBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20,18,20,12">
            <Border Style="{StaticResource DarkPanelFrameStyle}">
                <StackPanel>
                    <TextBlock x:Name="SelectedCoherenceDeviceText"
                               Text="No device selected"
                               FontSize="30"
                               FontWeight="Bold"
                               Margin="0,0,0,4" />
                    <TextBlock x:Name="CoherenceWindowSummaryText"
                               Text="RR-derived coherence follows The Coherent Heart peak-window method and also shows the Astral-compatible normalized score used by the app."
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource GraphiteBrush}" />
                </StackPanel>
            </Border>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource DarkPanelFrameStyle}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Coherence" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock x:Name="CoherenceValueText"
                                   Text="--"
                                   FontSize="54"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource FocusBlueBrush}" />
                        <TextBlock x:Name="CoherenceStateValueText"
                                   Text="Unavailable"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,4,0,0" />
                        <TextBlock x:Name="CoherenceTrackingValueText"
                                   Text="Waiting for RR input"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource GraphiteBrush}"
                                   Margin="0,8,0,0" />
                        <TextBlock x:Name="CoherenceConfidenceValueText"
                                   Text="Confidence --"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource GraphiteBrush}"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource PanelFrameStyle}">
                    <StackPanel>
                        <TextBlock Text="Control" Style="{StaticResource MetricLabelStyle}" />
                        <WrapPanel>
                            <Button Content="Reset tracker"
                                    Width="112"
                                    Margin="0,0,8,8"
                                    Click="OnResetTrackerClick" />
                            <Button Content="Apply tuning"
                                    Width="108"
                                    Margin="0,0,8,8"
                                    Click="OnApplyTuningClick" />
                            <Button Content="Restore defaults"
                                    Width="128"
                                    Margin="0,0,0,8"
                                    Background="{StaticResource AppPaperBrush}"
                                    Foreground="{StaticResource CarbonBrush}"
                                    BorderBrush="{StaticResource PanelEdgeBrush}"
                                    Click="OnRestoreDefaultsClick" />
                        </WrapPanel>
                        <TextBlock x:Name="CoherenceStatusText"
                                   Text="No device selected"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource GraphiteBrush}"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock Text="Readiness"
                       Style="{StaticResource SectionTitleStyle}"
                       Margin="0,0,0,8" />
            <Border Style="{StaticResource PanelFrameStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.15*" />
                        <ColumnDefinition Width="0.85*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,18,0">
                        <TextBlock x:Name="CoherenceRequirementText"
                                   Text="First valid value requires RR stabilization and nearly a full RR history window."
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="CoherenceWarmupHintText"
                                   Text="Connect a device and start RR streaming to begin buffering the first coherence window."
                                   FontSize="13"
                                   Foreground="{StaticResource GraphiteBrush}"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Valid RR run"
                                       Style="{StaticResource MetricLabelStyle}"
                                       Margin="0,0,0,0" />
                            <TextBlock x:Name="CoherenceReadinessStabilizationText"
                                       Grid.Column="1"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Right" />
                        </Grid>

                        <ProgressBar x:Name="CoherenceReadinessStabilizationBar"
                                     Grid.Row="1"
                                     Style="{StaticResource ReadinessProgressStyle}"
                                     Margin="0,4,0,0" />

                        <Grid Grid.Row="2"
                              Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Buffered RR window"
                                       Style="{StaticResource MetricLabelStyle}"
                                       Margin="0,0,0,0" />
                            <TextBlock x:Name="CoherenceReadinessCoverageText"
                                       Grid.Column="1"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Right" />
                        </Grid>

                        <ProgressBar x:Name="CoherenceReadinessCoverageBar"
                                     Grid.Row="3"
                                     Style="{StaticResource ReadinessProgressStyle}"
                                     Margin="0,4,0,0" />

                        <TextBlock x:Name="CoherenceReadinessRemainingText"
                                   Grid.Row="4"
                                   Margin="0,12,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource GraphiteBrush}"
                                   TextWrapping="Wrap" />
                    </Grid>
                </Grid>
            </Border>

            <TextBlock Text="Coherence telemetry"
                       Style="{StaticResource SectionTitleStyle}"
                       Margin="0,0,0,8" />
            <Border x:Name="CoherenceChartHost"
                    Style="{StaticResource PanelFrameStyle}"
                    Height="214"
                    Padding="0"
                    Margin="0,0,0,10" />

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PanelFrameStyle}" Margin="0,0,10,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="State" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock x:Name="CoherenceTelemetryTrackingText" Grid.Column="1" FontSize="14" FontWeight="SemiBold" />

                        <TextBlock Grid.Row="1" Text="Last RR" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock x:Name="CoherenceTelemetryLastRrText" Grid.Row="1" Grid.Column="1" FontSize="14" FontWeight="SemiBold" />

                        <TextBlock Grid.Row="2" Text="Heartbeat" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock x:Name="CoherenceTelemetryHeartbeatText" Grid.Row="2" Grid.Column="1" FontSize="14" FontWeight="SemiBold" />

                        <TextBlock Grid.Row="3" Text="RR seen" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock x:Name="CoherenceTelemetrySampleCountText" Grid.Row="3" Grid.Column="1" FontSize="14" FontWeight="SemiBold" />

                        <TextBlock Grid.Row="4" Text="Window fill" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock x:Name="CoherenceTelemetryCoverageText" Grid.Row="4" Grid.Column="1" FontSize="14" FontWeight="SemiBold" />

                        <TextBlock Grid.Row="5" Text="Valid RR run" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock x:Name="CoherenceTelemetryStabilizationText" Grid.Row="5" Grid.Column="1" FontSize="14" FontWeight="SemiBold" />
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource PanelFrameStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Last update" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock x:Name="CoherenceTelemetryLastUpdateText" Grid.Column="1" FontSize="14" FontWeight="SemiBold" />

                        <TextBlock Grid.Row="1" Text="Peak frequency" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock x:Name="CoherenceTelemetryPeakFrequencyText" Grid.Row="1" Grid.Column="1" FontSize="14" FontWeight="SemiBold" />

                        <TextBlock Grid.Row="2" Text="Peak band power" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock x:Name="CoherenceTelemetryPeakBandPowerText" Grid.Row="2" Grid.Column="1" FontSize="14" FontWeight="SemiBold" />

                        <TextBlock Grid.Row="3" Text="Total band power" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock x:Name="CoherenceTelemetryTotalPowerText" Grid.Row="3" Grid.Column="1" FontSize="14" FontWeight="SemiBold" />

                        <TextBlock Grid.Row="4" Text="Paper ratio" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock x:Name="CoherenceTelemetryPaperRatioText" Grid.Row="4" Grid.Column="1" FontSize="14" FontWeight="SemiBold" />

                        <TextBlock Grid.Row="5" Text="Normalized score" Style="{StaticResource MetricLabelStyle}" />
                        <TextBlock x:Name="CoherenceTelemetryNormalizedScoreText" Grid.Row="5" Grid.Column="1" FontSize="14" FontWeight="SemiBold" />
                    </Grid>
                </Border>
            </Grid>

            <TextBlock Text="Tuning"
                       Style="{StaticResource SectionTitleStyle}"
                       Margin="0,0,0,8" />
            <Border Style="{StaticResource PanelFrameStyle}">
                <StackPanel>
                    <TextBlock Margin="0,0,0,12"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource GraphiteBrush}"
                               TextWrapping="Wrap">
                        Fixed paper constants stay locked to the monograph method: peak search 0.04-0.26 Hz, peak window 0.030 Hz, and total band 0.0033-0.4 Hz.
                        These controls only change tracker readiness, RR history length, display smoothing, and freshness handling.
                    </TextBlock>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="118" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="118" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Min RR samples" Style="{StaticResource MetricLabelStyle}" />
                        <TextBox x:Name="CoherenceMinimumIbiSamplesBox"
                                 Grid.Column="1"
                                 Margin="0,0,0,8"
                                 ToolTip="Accepted RR intervals required before the tracker attempts a spectral solve." />
                        <TextBlock Grid.Column="3" Text="Window (s)" Style="{StaticResource MetricLabelStyle}" />
                        <TextBox x:Name="CoherenceWindowSecondsBox"
                                 Grid.Column="4"
                                 Margin="0,0,0,8"
                                 ToolTip="Rolling RR history length used for spline resampling and PSD analysis." />

                        <TextBlock Grid.Row="1" Text="Smoothing speed" Style="{StaticResource MetricLabelStyle}" />
                        <TextBox x:Name="CoherenceSmoothingSpeedBox"
                                 Grid.Row="1"
                                 Grid.Column="1"
                                 ToolTip="Exponential response speed for the displayed normalized coherence score." />
                        <TextBlock Grid.Row="1" Grid.Column="3" Text="Stale timeout (s)" Style="{StaticResource MetricLabelStyle}" />
                        <TextBox x:Name="CoherenceStaleTimeoutBox"
                                 Grid.Row="1"
                                 Grid.Column="4"
                                 ToolTip="How long a solved sample remains in Tracking before it is marked stale." />
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock Text="Coherence log"
                       Style="{StaticResource SectionTitleStyle}"
                       Margin="0,4,0,8" />
            <ListBox x:Name="CoherenceLogList"
                     Height="140"
                     Style="{StaticResource ConsoleListStyle}"
                     ItemContainerStyle="{StaticResource ConsoleListItemStyle}" />
        </StackPanel>
    </ScrollViewer>
</Window>
