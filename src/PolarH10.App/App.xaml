<Application x:Class="PolarH10.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <Color x:Key="AppPaperColor">#F1EEE6</Color>
        <Color x:Key="SurfaceLightColor">#E6E1D7</Color>
        <Color x:Key="CarbonColor">#111315</Color>
        <Color x:Key="GraphiteColor">#4B4F52</Color>
        <Color x:Key="GridGrayColor">#8A8E91</Color>
        <Color x:Key="SignalRedColor">#D92C2C</Color>
        <Color x:Key="HazardYellowColor">#D8D61A</Color>
        <Color x:Key="SafetyOrangeColor">#F05A22</Color>
        <Color x:Key="TelemetryCyanColor">#00A7A0</Color>

        <SolidColorBrush x:Key="AppPaperBrush" Color="{StaticResource AppPaperColor}" />
        <SolidColorBrush x:Key="SurfaceLightBrush" Color="{StaticResource SurfaceLightColor}" />
        <SolidColorBrush x:Key="CarbonBrush" Color="{StaticResource CarbonColor}" />
        <SolidColorBrush x:Key="GraphiteBrush" Color="{StaticResource GraphiteColor}" />
        <SolidColorBrush x:Key="GridBrush" Color="{StaticResource GridGrayColor}" />
        <SolidColorBrush x:Key="SignalRedBrush" Color="{StaticResource SignalRedColor}" />
        <SolidColorBrush x:Key="HazardYellowBrush" Color="{StaticResource HazardYellowColor}" />
        <SolidColorBrush x:Key="SafetyOrangeBrush" Color="{StaticResource SafetyOrangeColor}" />
        <SolidColorBrush x:Key="TelemetryCyanBrush" Color="{StaticResource TelemetryCyanColor}" />

        <FontFamily x:Key="UiFont">Bahnschrift Condensed</FontFamily>
        <FontFamily x:Key="MonoFont">Consolas</FontFamily>

        <Style TargetType="{x:Type Window}">
            <Setter Property="Background" Value="{StaticResource AppPaperBrush}" />
            <Setter Property="Foreground" Value="{StaticResource CarbonBrush}" />
            <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        </Style>

        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource CarbonBrush}" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>

        <Style TargetType="{x:Type GridSplitter}">
            <Setter Property="Background" Value="{StaticResource GraphiteBrush}" />
        </Style>

        <Style TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="{StaticResource AppPaperBrush}" />
            <Setter Property="Background" Value="{StaticResource CarbonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CarbonBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SafetyOrangeBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource SafetyOrangeBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource CarbonBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource HazardYellowBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource HazardYellowBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource HazardYellowBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource CarbonBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SurfaceLightBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource GridBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource GridBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="{StaticResource AppPaperBrush}" />
            <Setter Property="Foreground" Value="{StaticResource CarbonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CarbonBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource HazardYellowBrush}" />
                                <Setter TargetName="Chrome" Property="Background" Value="#FFF8F0" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SurfaceLightBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource GridBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource GridBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="{StaticResource CarbonBrush}" />
            <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type CheckBox}">
                        <StackPanel Orientation="Horizontal" SnapsToDevicePixels="True">
                            <Border x:Name="Box"
                                    Width="14"
                                    Height="14"
                                    Margin="0,0,8,0"
                                    BorderBrush="{StaticResource CarbonBrush}"
                                    BorderThickness="1"
                                    Background="{StaticResource AppPaperBrush}" />
                            <ContentPresenter VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="{StaticResource CarbonBrush}" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource CarbonBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource SafetyOrangeBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource GridBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource GridBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="{StaticResource AppPaperBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CarbonBrush}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style TargetType="{x:Type TabItem}">
            <Setter Property="Foreground" Value="{StaticResource GraphiteBrush}" />
            <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CarbonBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Margin="0,0,6,0"
                                SnapsToDevicePixels="True">
                            <TextBlock x:Name="HeaderText"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="{TemplateBinding Padding}"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       Foreground="{TemplateBinding Foreground}"
                                       Text="{TemplateBinding Header}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource CarbonBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource CarbonBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource HazardYellowBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource SafetyOrangeBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource GridBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
