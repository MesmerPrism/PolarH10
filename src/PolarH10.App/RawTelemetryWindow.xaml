<Window x:Class="PolarH10.App.RawTelemetryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Polar H10 // Raw Telemetry"
        Width="1260"
        Height="920"
        MinWidth="1080"
        MinHeight="760"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="PanelFrameStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource AppPaperBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelEdgeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="DarkPanelFrameStyle" TargetType="Border" BasedOn="{StaticResource PanelFrameStyle}">
            <Setter Property="Background" Value="{StaticResource SurfaceTintBrush}" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource CarbonBrush}" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20,18,20,12">
            <Border Style="{StaticResource DarkPanelFrameStyle}">
                <StackPanel>
                    <TextBlock x:Name="SelectedDeviceText"
                               Text="No device selected"
                               FontSize="30"
                               FontWeight="Bold"
                               Margin="0,0,0,4" />
                    <TextBlock x:Name="TrackingSummaryText"
                               Text="Raw telemetry follows the selected chart targets."
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource GraphiteBrush}" />
                </StackPanel>
            </Border>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="HrChartHost"
                        Grid.Column="0"
                        Style="{StaticResource PanelFrameStyle}"
                        Height="154"
                        Padding="0"
                        Margin="0,0,10,10" />
                <Border x:Name="RrChartHost"
                        Grid.Column="1"
                        Style="{StaticResource PanelFrameStyle}"
                        Height="154"
                        Padding="0"
                        Margin="0,0,0,10" />
            </Grid>

            <TextBlock Text="ECG"
                       Style="{StaticResource SectionTitleStyle}"
                       Margin="0,0,0,8" />
            <Border x:Name="EcgChartHost"
                    Style="{StaticResource PanelFrameStyle}"
                    Height="234"
                    Padding="0"
                    Margin="0,0,0,10" />

            <TextBlock Text="Acceleration"
                       Style="{StaticResource SectionTitleStyle}"
                       Margin="0,0,0,8" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="AccXChartHost"
                        Grid.Column="0"
                        Style="{StaticResource PanelFrameStyle}"
                        Height="154"
                        Padding="0"
                        Margin="0,0,10,0" />
                <Border x:Name="AccYChartHost"
                        Grid.Column="1"
                        Style="{StaticResource PanelFrameStyle}"
                        Height="154"
                        Padding="0"
                        Margin="0,0,10,0" />
                <Border x:Name="AccZChartHost"
                        Grid.Column="2"
                        Style="{StaticResource PanelFrameStyle}"
                        Height="154"
                        Padding="0" />
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Window>
